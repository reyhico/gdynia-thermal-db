# Gdynia Thermal DB - Environment Variables Example
# Copy this file to .env and fill in any values as needed

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Data directory override (optional, defaults to ./data)
# DATA_DIR=./data

# Output directory override (optional, defaults to ./outputs)
# OUTPUT_DIR=./outputs

# HTTP request timeout in seconds (default: 30)
HTTP_TIMEOUT=30

# HTTP user agent string
HTTP_USER_AGENT=gdynia-thermal-db/1.0 (research project; contact: see README)
